# .gitattributes - Controls how Git handles files in this repository.
#
# Main purpose for this project:
# - Ensure consistent line endings (LF) across Windows, macOS, and Linux.
# - Prevent the CRLF warnings we saw during the initial commits.
# - Mark binary files correctly.
# - Help GitHub's linguist correctly identify languages.

# Automatically detect text files and normalize line endings to LF on commit
* text=auto

# Force LF line endings for common text file types
*.py        text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.sh        text eol=lf
*.ps1       text eol=lf
*.bat       text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf

# Explicitly mark binary files (never convert line endings)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.exe       binary
*.dll       binary
*.so        binary
*.dylib     binary
*.pyc       binary
*.pyo       binary

# Help GitHub linguist stats
*.py linguist-language=Python
*.md linguist-documentation=true
tests/** linguist-documentation=false

# Ignore generated/lock files in diffs if needed (optional)
# poetry.lock linguist-generated=true
# package-lock.json linguist-generated=true